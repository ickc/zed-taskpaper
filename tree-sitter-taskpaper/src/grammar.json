{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "taskpaper",
  "rules": {
    "document": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_item"
      }
    },
    "_item": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "project"
        },
        {
          "type": "SYMBOL",
          "name": "task"
        },
        {
          "type": "SYMBOL",
          "name": "note"
        }
      ]
    },
    "project": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_project_begin"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "name",
              "content": {
                "type": "SYMBOL",
                "name": "text"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "tag"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_eol"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_children"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "task": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_task_begin"
        },
        {
          "type": "SYMBOL",
          "name": "marker"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "text"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "tag"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_eol"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_children"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "note": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_note_begin"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "text"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "tag"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_eol"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_children"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "_children": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_indent"
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "_item"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_dedent"
        }
      ]
    },
    "marker": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "-[ \\t]?"
      }
    },
    "tag": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "ALIAS",
            "content": {
              "type": "TOKEN",
              "content": {
                "type": "PATTERN",
                "value": "@([A-Za-z0-9_.\\-]|[^\\x00-\\x7F])+"
              }
            },
            "named": true,
            "value": "tag_name"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "IMMEDIATE_TOKEN",
                  "content": {
                    "type": "STRING",
                    "value": "("
                  }
                },
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "FIELD",
                      "name": "value",
                      "content": {
                        "type": "ALIAS",
                        "content": {
                          "type": "IMMEDIATE_TOKEN",
                          "content": {
                            "type": "PATTERN",
                            "value": "[^)\\r\\n]*"
                          }
                        },
                        "named": true,
                        "value": "tag_value"
                      }
                    },
                    {
                      "type": "BLANK"
                    }
                  ]
                },
                {
                  "type": "IMMEDIATE_TOKEN",
                  "content": {
                    "type": "STRING",
                    "value": ")"
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [
    {
      "type": "SYMBOL",
      "name": "_indent"
    },
    {
      "type": "SYMBOL",
      "name": "_dedent"
    },
    {
      "type": "SYMBOL",
      "name": "_eol"
    },
    {
      "type": "SYMBOL",
      "name": "_project_begin"
    },
    {
      "type": "SYMBOL",
      "name": "_task_begin"
    },
    {
      "type": "SYMBOL",
      "name": "_note_begin"
    },
    {
      "type": "SYMBOL",
      "name": "text"
    },
    {
      "type": "SYMBOL",
      "name": "_error_sentinel"
    }
  ],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}